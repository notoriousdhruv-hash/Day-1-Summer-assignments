#include <stdio.h>

int main() {
    int num;

    // Prompt the user for an integer
    printf("Enter an integer to print its multiplication table: ");
    scanf("%d", &num);

    printf("\nMultiplication Table for %d:\n", num);
    printf("----------------------------\n");

    // Loop from 1 to 10
    for (int i = 1; i <= 10; ++i) {
        // Print the table in the format: num x i = result
        printf("%d x %d = %d\n", num, i, num * i);
    }

    return 0;
}
